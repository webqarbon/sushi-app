# ===========================================
# FROZEN MARKET — Production Environment
# ===========================================
# Copy to .env and fill with your values.
# For production: set these in your hosting (Vercel, etc.)

# --- Required ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Production URL (required for auth, checkout, webhooks)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-bot-token
ADMIN_TELEGRAM_ID=your-admin-chat-id

# Optional: Webhook secret (set when configuring Telegram setWebhook)
# TELEGRAM_WEBHOOK_SECRET=your-secret

# --- Payment & Delivery ---
MONOBANK_API_KEY=your-monobank-merchant-token
NOVA_POSHTA_API_KEY=your-novaposhta-api-key

# --- Site Config (optional overrides) ---
# NEXT_PUBLIC_SITE_NAME=FROZEN MARKET
# NEXT_PUBLIC_SITE_SHORT_NAME=FROZEN
# NEXT_PUBLIC_CONTACT_PHONE=+380 95 372 75 99
# NEXT_PUBLIC_CONTACT_PHONE_RAW=+380953727599
# NEXT_PUBLIC_CONTACT_ADDRESS=вул. Грушевського, 97в
# NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/your_profile
# NEXT_PUBLIC_TELEGRAM_URL=https://t.me/your_handle
# NEXT_PUBLIC_TELEGRAM_HANDLE=@your_handle

# --- Payment Requisites (REQUIRED for production) ---
# Replace with real bank details before launch
NEXT_PUBLIC_PAYMENT_BANK_NAME=АТ «Назва банку»
NEXT_PUBLIC_PAYMENT_IBAN=UA123456789012345678901234567
NEXT_PUBLIC_PAYMENT_RECIPIENT=ТОВ «Назва компанії»
NEXT_PUBLIC_PAYMENT_EDRPOU=12345678
NEXT_PUBLIC_PAYMENT_PURPOSE=Оплата замовлення на FROZEN MARKET

# --- Admin (for initial setup only) ---
# ADMIN_USER_EMAIL=admin@your-domain.com
# ADMIN_USER_PASSWORD=secure-password
